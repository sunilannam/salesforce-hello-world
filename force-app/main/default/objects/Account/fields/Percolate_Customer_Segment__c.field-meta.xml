    <trackFeedHistory>false</trackFeedHistory>
    <trackHistory>false</trackHistory>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>CMP</fullName>
                <default>true</default>
                <label>CMP</label>
            </value>
            <value>
                <fullName>Social</fullName>
                <default>false</default>
                <label>Social</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
