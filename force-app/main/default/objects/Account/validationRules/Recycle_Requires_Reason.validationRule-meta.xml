<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Recycle_Requires_Reason</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(CONTAINS($Profile.Name, &apos;Marketo Sync&apos;)) &amp;&amp;
(ISPICKVAL( Account_Status__c , &quot;Recycle&quot;) &amp;&amp;
ISBLANK(TEXT(Recycled_Reason__c)))&amp;&amp;
(ISNEW() ||
ISCHANGED(Account_Status__c))</errorConditionFormula>
    <errorDisplayField>Account_Status__c</errorDisplayField>
    <errorMessage>Please enter a Recycle Reason.</errorMessage>
</ValidationRule>
