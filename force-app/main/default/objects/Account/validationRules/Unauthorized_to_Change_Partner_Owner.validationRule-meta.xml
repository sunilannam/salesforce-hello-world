<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Unauthorized_to_Change_Partner_Owner</fullName>
    <active>true</active>
    <errorConditionFormula>RecordType.Name = &apos;Partner&apos; &amp;&amp;
ISCHANGED(OwnerId) &amp;&amp;
$Profile.Name &lt;&gt;&apos;System Administrator&apos; &amp;&amp;
NOT($Permission.Partner_Field_Permissions)</errorConditionFormula>
    <errorMessage>Unauthorized to change Partner Account Owner. Please reach out to Partner Operations for assistance.</errorMessage>
</ValidationRule>
