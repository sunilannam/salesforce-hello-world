<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Referral_Rate_for_Schedule_B</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    INCLUDES(Signed_Schedule_Type__c, &quot;Referral Agreement&quot;),
    ISBLANK(Referral_Partner_Rate__c),
    $RecordType.Name = &quot;Partner&quot;
)</errorConditionFormula>
    <errorDisplayField>Referral_Partner_Rate__c</errorDisplayField>
    <errorMessage>Referral Partner Rate is required when &apos;Schedule B - Seismic Referral to Partner&apos; is selected.</errorMessage>
</ValidationRule>
