<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Restrict_Field_Access_on_Partner_Account</fullName>
    <active>true</active>
    <errorConditionFormula>RecordType.Name = &apos;Partner&apos; &amp;&amp;
(
  ISCHANGED(Type) ||
  ISCHANGED(Signed_Schedule_Type__c)
) &amp;&amp;
$Profile.Name &lt;&gt; &apos;System Administrator&apos; &amp;&amp;
NOT($Permission.Partner_Operations_Permissions)</errorConditionFormula>
    <errorMessage>You do not have permission to update Type or Signed Schedule Type for Partner records. Please reach out to Partner Operations.</errorMessage>
</ValidationRule>
