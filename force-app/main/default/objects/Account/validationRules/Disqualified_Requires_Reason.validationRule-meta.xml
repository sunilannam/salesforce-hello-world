<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Disqualified_Requires_Reason</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(CONTAINS($Profile.Name, &apos;Marketo Sync&apos;)) &amp;&amp;
(ISPICKVAL(Account_Status__c, &quot;Disqualified&quot;) &amp;&amp;
ISBLANK(TEXT(Disqualified_Reason__c)))&amp;&amp;
(ISNEW() ||
ISCHANGED( Account_Status__c ))</errorConditionFormula>
    <errorDisplayField>Account_Status__c</errorDisplayField>
    <errorMessage>Please enter a Disqualified Reason.</errorMessage>
</ValidationRule>
