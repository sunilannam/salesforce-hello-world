<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Qualtrics_Survey_Fields_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Sent_Survey__c = TRUE,
OR(ISBLANK(Survey_Email_Recipient__c),
ISBLANK(Survey_Passcode__c)))</errorConditionFormula>
    <errorDisplayField>Sent_Survey__c</errorDisplayField>
    <errorMessage>Before you can send a survey, you must define the &quot;Survey Passcode&quot; and &quot;Survey Recipient&quot; fields.</errorMessage>
</ValidationRule>
